<!-- =========================
🤖 IA DEMOFLOW
========================= -->

<div class="card border-0 shadow-sm mb-4">

  <div class="card-body">

    <!-- HEADER IA -->

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">

      <div>

        <h4 class="mb-1">
          🤖 IA DemoFlow Assistant
        </h4>

        <p class="text-muted mb-0">
          Inteligencia artificial para analizar tus demos,
          detectar tecnologías y ayudarte a vender más.
        </p>

      </div>

      <div class="d-flex gap-2 align-items-center">

        <span class="badge bg-dark p-3">
          💎 Créditos:
          <%= usuario.creditos || 0 %>
        </span>

        <% if(usuario.acceso_ia){ %>

          <span class="badge bg-success p-3">
            🟢 IA ACTIVA
          </span>

        <% } else { %>

          <span class="badge bg-warning text-dark p-3">
            🟡 IA FREE
          </span>

        <% } %>

      </div>

    </div>

    <!-- ALERTA IA -->

    <div class="alert alert-primary d-flex align-items-center gap-3 mb-4">

      <i class="bi bi-robot fs-5"></i>

      <div>
        🤖 DemoFlow IA monitorea tus demos
        y analiza proyectos en tiempo real.
      </div>

    </div>

    <!-- BOTÓN IA -->

    <div class="mb-4">

      <% if(usuario.acceso_ia){ %>

        <form
          action="/ia/analizar-dashboard"
          method="POST"
        >

          <button
            type="submit"
            class="btn btn-primary btn-lg"
          >
            🤖 Analizar mi plataforma con IA
          </button>

        </form>

      <% } else { %>

        <a
          href="/premium"
          class="btn btn-dark btn-lg"
        >
          🚀 Mejorar a IA Premium
        </a>

      <% } %>

    </div>

    <!-- GRID -->

    <div class="row">

      <!-- ESTADO -->

      <div class="col-md-3 mb-3">

        <div class="border rounded p-3 h-100">

          <h6>
            🚀 Estado IA
          </h6>

          <% if(usuario.acceso_ia){ %>

            <p class="text-success mb-0">

              <%= iaDashboard
                ? iaDashboard.estado
                : 'IA activada correctamente.'
              %>

            </p>

          <% } else { %>

            <p class="text-warning mb-0">
              Modo gratuito activo.
            </p>

          <% } %>

        </div>

      </div>

      <!-- RECOMENDACIÓN -->

      <div class="col-md-3 mb-3">

        <div class="border rounded p-3 h-100">

          <h6>
            📈 Recomendación IA
          </h6>

          <p class="mb-0 text-muted">

            <%= iaDashboard
              ? iaDashboard.recomendacion
              : 'Agrega más screenshots y demos en vivo para aumentar conversiones.'
            %>

          </p>

        </div>

      </div>

      <!-- POTENCIAL -->

      <div class="col-md-3 mb-3">

        <div class="border rounded p-3 h-100">

          <h6>
            🔥 Potencial de venta
          </h6>

          <p class="mb-0 text-primary">

            <%= iaDashboard
              ? iaDashboard.potencial
              : 'Tu perfil tiene alto potencial SaaS comercial.'
            %>

          </p>

        </div>

      </div>

      <!-- ESTADÍSTICAS -->

      <div class="col-md-3 mb-3">

        <div class="border rounded p-3 h-100">

          <h6>
            📊 Estadísticas IA
          </h6>

          <p class="mb-1">
            Proyectos:
            <strong>
              <%= iaDashboard ? iaDashboard.totalProyectos : 0 %>
            </strong>
          </p>

          <p class="mb-1">
            Demos activas:
            <strong>
              <%= iaDashboard ? iaDashboard.demosConUrl : 0 %>
            </strong>
          </p>

          <p class="mb-1">
            Sails.js:
            <strong>
              <%= iaDashboard ? iaDashboard.proyectosSails : 0 %>
            </strong>
          </p>

          <p class="mb-0">
            HTML:
            <strong>
              <%= iaDashboard ? iaDashboard.proyectosHtml : 0 %>
            </strong>
          </p>

        </div>

      </div>

    </div>

    <!-- IA INSIGHTS -->

    <div class="border rounded p-4 mt-4">

      <h5 class="mb-3">
        🧠 IA Insights
      </h5>

      <div class="row">

        <div class="col-md-4 mb-3">

          <div class="border rounded p-3 h-100">

            <h6>
              🚀 Sails.js
            </h6>

            <p class="text-muted mb-0">
              Tus proyectos Sails.js tienen
              alto potencial comercial.
            </p>

          </div>

        </div>

        <div class="col-md-4 mb-3">

          <div class="border rounded p-3 h-100">

            <h6>
              🌐 Conversión
            </h6>

            <p class="text-muted mb-0">
              Las demos con screenshots y links
              en vivo convierten mucho más.
            </p>

          </div>

        </div>

        <div class="col-md-4 mb-3">

          <div class="border rounded p-3 h-100">

            <h6>
              💰 SaaS
            </h6>

            <p class="text-muted mb-0">
              DemoFlow ya tiene estructura
              para convertirse en SaaS.
            </p>

          </div>

        </div>

      </div>

    </div>

    <!-- ÚLTIMO ANÁLISIS -->

    <div class="mt-4">

      <p class="small text-muted mb-0">
        🤖 Último análisis IA:
        hace unos minutos.
      </p>

    </div>

  </div>

</div>