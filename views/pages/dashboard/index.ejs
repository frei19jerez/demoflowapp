<body class="bg-light">

  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
      <div>
        <h1 class="h3 mb-1">Mi panel</h1>
        <p class="text-muted mb-0">Aquí verás tus proyectos y demos.</p>
      </div>
      <a href="/proyecto/nuevo" class="btn btn-primary">+ Nuevo proyecto</a>
    </div>

    <% if (proyectos && proyectos.length > 0) { %>
      <div class="row">
        <% proyectos.forEach(function(proyecto){ %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
              <div class="card-body d-flex flex-column">

                <h5 class="mb-2"><%= proyecto.nombre %></h5>

                <p class="text-muted mb-2">
                  <%= proyecto.descripcion || 'Sin descripción' %>
                </p>

                <p class="mb-2">
                  <strong>Estado:</strong> <%= proyecto.estado || 'borrador' %>
                </p>

                <p class="mb-3">
                  <strong>Tecnología:</strong> <%= proyecto.tecnologia || '-' %>
                </p>

                <div class="mt-auto pt-3 d-flex flex-wrap gap-2">
                  <a href="/proyecto/<%= proyecto.id %>" class="btn btn-outline-secondary btn-sm">
                    Ver detalle
                  </a>

                  <% if (proyecto.urlDemo) { %>
                    <a href="<%= proyecto.urlDemo %>" target="_blank" class="btn btn-primary btn-sm">
                      Ver en vivo
                    </a>
                  <% } %>

                  <form action="/proyecto/<%= proyecto.id %>/eliminar" method="POST" onsubmit="return confirm('¿Seguro que deseas eliminar este proyecto?');" class="d-inline">
                    <button type="submit" class="btn btn-danger btn-sm">
                      Eliminar
                    </button>
                  </form>
                </div>

              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info">
        Aún no tienes proyectos creados.
      </div>
    <% } %>
  </div>

</body>