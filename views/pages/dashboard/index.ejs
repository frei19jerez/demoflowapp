<link rel="stylesheet" href="/styles/ia-demoflow.css">

<!-- =========================
🤖 IA DEMOFLOW
========================= -->

<div class="card border-0 shadow-sm mb-4 ia-demoflow-card">

  <div class="card-body">

    <!-- HEADER IA -->

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">

      <div>

        <h4 class="mb-1 ia-demoflow-title">
          🤖 IA DemoFlow Assistant
        </h4>

        <p class="mb-0 ia-demoflow-subtitle">
          Inteligencia artificial para analizar tus demos,
          detectar tecnologías y ayudarte a vender más.
        </p>

      </div>

      <div class="d-flex gap-2 align-items-center">

        <span class="badge bg-dark ia-badge">
          💎 Créditos:
          <%= usuario.creditos || 0 %>
        </span>

        <% if(usuario.acceso_ia){ %>

          <span class="badge bg-success ia-badge">
            🟢 IA ACTIVA
          </span>

        <% } else { %>

          <span class="badge bg-warning text-dark ia-badge">
            🟡 IA FREE
          </span>

        <% } %>

      </div>

    </div>

    <!-- ALERTA IA -->

    <div class="alert ia-alert d-flex align-items-center gap-3 mb-4">

      <i class="bi bi-robot fs-5"></i>

      <div>
        🤖 DemoFlow IA monitorea tus demos
        y analiza proyectos en tiempo real.
      </div>

    </div>

    <!-- BOTÓN IA -->

    <div class="mb-4">

      <% if(usuario.acceso_ia){ %>

        <form
          action="/ia/analizar-dashboard"
          method="POST"
        >

          <button
            type="submit"
            class="btn btn-primary btn-lg ia-premium-btn"
          >
            🤖 Analizar mi plataforma con IA
          </button>

        </form>

      <% } else { %>

        <a
          href="/premium"
          class="btn btn-dark btn-lg ia-premium-btn"
        >
          🚀 Mejorar a IA Premium
        </a>

      <% } %>

    </div>

    <!-- GRID -->

    <div class="row">

      <!-- ESTADO -->

      <div class="col-md-3 mb-3">

        <div class="ia-box">

          <h6>
            🚀 Estado IA
          </h6>

          <% if(usuario.acceso_ia){ %>

            <p class="text-success mb-0">

              <%= iaDashboard
                ? iaDashboard.estado
                : 'IA activada correctamente.'
              %>

            </p>

          <% } else { %>

            <p class="text-warning mb-0">
              Modo gratuito activo.
            </p>

          <% } %>

        </div>

      </div>

      <!-- RECOMENDACIÓN -->

      <div class="col-md-3 mb-3">

        <div class="ia-box">

          <h6>
            📈 Recomendación IA
          </h6>

          <p class="mb-0 text-muted">

            <%= iaDashboard
              ? iaDashboard.recomendacion
              : 'Agrega más screenshots y demos en vivo para aumentar conversiones.'
            %>

          </p>

        </div>

      </div>

      <!-- POTENCIAL -->

      <div class="col-md-3 mb-3">

        <div class="ia-box">

          <h6>
            🔥 Potencial de venta
          </h6>

          <p class="mb-0 text-primary">

            <%= iaDashboard
              ? iaDashboard.potencial
              : 'Tu perfil tiene alto potencial SaaS comercial.'
            %>

          </p>

        </div>

      </div>

      <!-- ESTADÍSTICAS -->

      <div class="col-md-3 mb-3">

        <div class="ia-box">

          <h6>
            📊 Estadísticas IA
          </h6>

          <p class="mb-1">
            Proyectos:
            <strong class="ia-stat-number">
              <%= iaDashboard ? iaDashboard.totalProyectos : 0 %>
            </strong>
          </p>

          <p class="mb-1">
            Demos activas:
            <strong class="ia-stat-number">
              <%= iaDashboard ? iaDashboard.demosConUrl : 0 %>
            </strong>
          </p>

          <p class="mb-1">
            Sails.js:
            <strong class="ia-stat-number">
              <%= iaDashboard ? iaDashboard.proyectosSails : 0 %>
            </strong>
          </p>

          <p class="mb-0">
            HTML:
            <strong class="ia-stat-number">
              <%= iaDashboard ? iaDashboard.proyectosHtml : 0 %>
            </strong>
          </p>

        </div>

      </div>

    </div>

    <!-- IA INSIGHTS -->

    <div class="ia-insights mt-4">

      <h5 class="mb-3">
        🧠 IA Insights
      </h5>

      <div class="row">

        <div class="col-md-4 mb-3">

          <div class="ia-insight-box">

            <h6>
              🚀 Sails.js
            </h6>

            <p class="text-muted mb-0">
              Tus proyectos Sails.js tienen
              alto potencial comercial.
            </p>

          </div>

        </div>

        <div class="col-md-4 mb-3">

          <div class="ia-insight-box">

            <h6>
              🌐 Conversión
            </h6>

            <p class="text-muted mb-0">
              Las demos con screenshots y links
              en vivo convierten mucho más.
            </p>

          </div>

        </div>

        <div class="col-md-4 mb-3">

          <div class="ia-insight-box">

            <h6>
              💰 SaaS
            </h6>

            <p class="text-muted mb-0">
              DemoFlow ya tiene estructura
              para convertirse en SaaS.
            </p>

          </div>

        </div>

      </div>

    </div>

    <!-- ÚLTIMO ANÁLISIS -->

    <div class="mt-4">

      <p class="ia-last-analysis mb-0">
        🤖 Último análisis IA:
        hace unos minutos.
      </p>

    </div>

  </div>

</div>

<!-- IA ANALYTICS CHARTS -->

<div class="ia-insights mt-4">

  <h5 class="mb-4">
    📊 Analytics IA DemoFlow
  </h5>

  <div
    id="iaChartData"
    data-total-proyectos="<%= iaDashboard ? iaDashboard.totalProyectos : 0 %>"
    data-demos-url="<%= iaDashboard ? iaDashboard.demosConUrl : 0 %>"
    data-sails="<%= iaDashboard ? iaDashboard.proyectosSails : 0 %>"
    data-html="<%= iaDashboard ? iaDashboard.proyectosHtml : 0 %>"
  ></div>

  <div class="row">

    <div class="col-md-6 mb-4">
      <div class="ia-insight-box">
        <h6>🚀 Demos activas</h6>
        <canvas id="chartDemos"></canvas>
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <div class="ia-insight-box">
        <h6>🧠 Tecnologías detectadas</h6>
        <canvas id="chartTecnologias"></canvas>
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <div class="ia-insight-box">
        <h6>👁️ Vistas estimadas</h6>
        <canvas id="chartVistas"></canvas>
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <div class="ia-insight-box">
        <h6>🔥 IA Score comercial</h6>
        <canvas id="chartScore"></canvas>
      </div>
    </div>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/ia-demoflow-charts.js"></script>