<link rel="stylesheet" href="/styles/nuevo.css">

<div class="nuevo-page">
  <div class="nuevo-card">

    <div class="nuevo-header">
      <h1>+ Nuevo proyecto</h1>
      <p>
        Sube un ZIP, importa desde Git o registra una URL externa para mostrar tu proyecto en DemoFlow.
      </p>
    </div>

    <form
      id="formProyecto"
      action="/proyecto/crear"
      method="POST"
      enctype="multipart/form-data"
    >

      <div class="form-grupo">
        <label for="metodoEntrada">Método de carga</label>
        <select name="metodoEntrada" id="metodoEntrada">
          <option value="zip">Subir archivo ZIP</option>
          <option value="git">Importar desde Git</option>
          <option value="externo">Registrar URL externa</option>
        </select>
      </div>

      <div class="form-grupo">
        <label for="nombre">Nombre del proyecto</label>
        <input
          type="text"
          name="nombre"
          id="nombre"
          required
          placeholder="Ej: Portal de noticias"
        >
      </div>

      <div class="form-grupo">
        <label for="slug">Slug / nombre corto</label>
        <input
          type="text"
          name="slug"
          id="slug"
          required
          placeholder="Ej: portal-noticias"
        >
        <small>
          Se usará para la ruta del demo, por ejemplo:
          <strong>/demo/portal-noticias</strong>
        </small>
      </div>

      <div class="form-grupo">
        <label for="tipoProyecto">Tipo de proyecto</label>
        <select name="tipoProyecto" id="tipoProyecto">
          <option value="html">Página HTML</option>
          <option value="node">Aplicación Node.js</option>
          <option value="sails">Aplicación Sails.js</option>
          <option value="externo">Demostración externa</option>
        </select>
      </div>

      <div class="form-grupo">
        <label for="tecnologia">Tecnología</label>
        <input
          type="text"
          name="tecnologia"
          id="tecnologia"
          placeholder="Ej: HTML + CSS + JavaScript"
        >
      </div>

      <div id="bloqueZip">

        <div class="form-grupo">
          <label for="archivoDemo">Subir archivo demo (.zip o .html)</label>
          <input
            type="file"
            name="archivoDemo"
            id="archivoDemo"
            accept=".zip,.html,.htm"
          >

          <small id="ayudaArchivo">
            Puedes subir un archivo ZIP o un HTML para publicarlo en DemoFlow.
          </small>

          <div
            id="nombreArchivoSeleccionado"
            class="archivo-seleccionado"
          ></div>
        </div>

        <div id="selectorCarpetaSails" class="form-grupo oculto">
          <label for="carpetaSails">O seleccionar carpeta Sails completa</label>

          <input
            type="file"
            id="carpetaSails"
            webkitdirectory
            directory
            multiple
          >

          <small>
            DemoFlow creará un ZIP limpio ignorando node_modules, .git, .tmp, uploads y archivos pesados.
          </small>
        </div>

        <div id="bloqueCarpetaDemo" class="form-grupo">
          <label for="carpetaDemo">Carpeta demo (opcional)</label>
          <input
            type="text"
            name="carpetaDemo"
            id="carpetaDemo"
            placeholder="Ej: aviator-freimel"
          >
          <small>
            Si no la escribes, DemoFlow usará el slug automáticamente.
          </small>
        </div>

      </div>

      <div id="bloqueGit" class="oculto">

        <div class="form-grupo">
          <label for="urlRepositorio">URL del repositorio</label>
          <input
            type="url"
            name="urlRepositorio"
            id="urlRepositorio"
            placeholder="https://github.com/usuario/proyecto"
          >
        </div>

        <div class="form-grupo">
          <label for="ramaGit">Rama (opcional)</label>
          <input
            type="text"
            name="ramaGit"
            id="ramaGit"
            placeholder="main"
          >
        </div>

      </div>

      <div id="bloqueExterno" class="oculto">

        <div class="form-grupo">
          <label for="urlDemo">URL o ruta de la demostración</label>
          <input
            type="text"
            name="urlDemo"
            id="urlDemo"
            placeholder="https://midemo.com"
          >

          <small id="ayudaDemo">
            Si es externa:
            <strong>https://midemo.com</strong>
          </small>
        </div>

      </div>

      <div id="bloqueRuntime" class="oculto">

        <div class="form-grupo">
          <label for="comandoInicio">Comando de inicio (opcional)</label>
          <input
            type="text"
            name="comandoInicio"
            id="comandoInicio"
            placeholder="Ej: npm start o node app.js"
          >
        </div>

        <div class="form-grupo">
          <label for="archivoEntrada">Archivo de entrada (opcional)</label>
          <input
            type="text"
            name="archivoEntrada"
            id="archivoEntrada"
            placeholder="Ej: app.js"
          >
        </div>

      </div>

      <div class="form-grupo">
        <label for="descripcion">Descripción</label>
        <textarea
          name="descripcion"
          id="descripcion"
          rows="5"
          placeholder="Describe qué hace esta aplicación o demostración..."
        ></textarea>
      </div>

      <div id="cargaBox" class="carga-box oculto">

        <div class="carga-header">
          <strong>Procesando proyecto...</strong>
          <span id="cargaTexto">Preparando...</span>
        </div>

        <div class="barra-contenedor">
          <div id="barraCarga"></div>
        </div>

      </div>

      <div class="acciones-form">

        <button
          id="btnGuardarProyecto"
          type="submit"
          class="btn-guardar"
        >
          Guardar proyecto
        </button>

        <a href="/dashboard" class="btn-volver">
          Volver
        </a>

      </div>

    </form>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
<script src="/js/sails-folder-builder.js"></script>
<script src="/js/nuevo.js"></script>