<div style="font-family: Arial, sans-serif; background:#f5f7fb; min-height:100vh; padding:40px 20px;">
  <div style="max-width:900px; margin:0 auto; background:#fff; padding:30px; border-radius:18px; box-shadow:0 8px 24px rgba(0,0,0,0.08);">

    <div style="margin-bottom:25px;">
      <h1 style="margin:0; font-size:34px; color:#111827;">+ Nuevo proyecto</h1>
      <p style="margin-top:10px; color:#6b7280; font-size:17px;">
        Sube un ZIP, importa desde Git o registra una URL externa para mostrar tu proyecto en DemoFlow.
      </p>
    </div>

    <form id="formProyecto" action="/proyecto/crear" method="POST" enctype="multipart/form-data">

      <div style="margin-bottom:22px;">
        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
          Método de carga
        </label>

        <select
          name="metodoEntrada"
          id="metodoEntrada"
          onchange="cambiarMetodoEntrada()"
          style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
          <option value="zip">Subir archivo ZIP</option>
          <option value="git">Importar desde Git</option>
          <option value="externo">Registrar URL externa</option>
        </select>
      </div>

      <div style="margin-bottom:18px;">
        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
          Nombre del proyecto
        </label>
        <input
          type="text"
          name="nombre"
          id="nombre"
          required
          placeholder="Ej: Portal de noticias"
          style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
      </div>

      <div style="margin-bottom:18px;">
        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
          Slug / nombre corto
        </label>
        <input
          type="text"
          name="slug"
          id="slug"
          required
          placeholder="Ej: portal-noticias"
          style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
        <small style="color:#6b7280;">
          Se usará para la ruta del demo, por ejemplo: <strong>/demo/portal-noticias</strong>
        </small>
      </div>

      <div style="margin-bottom:18px;">
        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
          Tipo de proyecto
        </label>
        <select
          name="tipoProyecto"
          id="tipoProyecto"
          onchange="cambiarTipoProyecto()"
          style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
          <option value="html">Página HTML</option>
          <option value="node">Aplicación Node.js</option>
          <option value="sails">Aplicación Sails.js</option>
          <option value="externo">Demostración externa</option>
        </select>
      </div>

      <div style="margin-bottom:18px;">
        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
          Tecnología
        </label>
        <input
          type="text"
          name="tecnologia"
          id="tecnologia"
          placeholder="Ej: HTML + CSS + JavaScript"
          style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
      </div>

      <div id="bloqueZip">

        <div style="margin-bottom:18px;">
          <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
            Subir archivo demo (.zip o .html)
          </label>
          <input
            type="file"
            name="archivoDemo"
            id="archivoDemo"
            accept=".zip,.html,.htm"
            onchange="mostrarNombreArchivo()"
            style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px; background:#fff;">
          <small id="ayudaArchivo" style="color:#6b7280;">
            Puedes subir un archivo ZIP o un HTML para publicarlo en DemoFlow.
          </small>
          <div id="nombreArchivoSeleccionado" style="margin-top:8px; color:#2563eb; font-size:14px; display:none;"></div>
        </div>

        <div id="bloqueCarpetaDemo" style="margin-bottom:18px;">
          <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
            Carpeta demo (opcional)
          </label>
          <input
            type="text"
            name="carpetaDemo"
            id="carpetaDemo"
            placeholder="Ej: aviator-freimel"
            style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
          <small style="color:#6b7280;">
            Si no la escribes, DemoFlow usará el slug automáticamente.
          </small>
        </div>

      </div>

      <div id="bloqueGit" style="display:none;">

        <div style="margin-bottom:18px;">
          <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
            URL del repositorio
          </label>
          <input
            type="url"
            name="urlRepositorio"
            id="urlRepositorio"
            placeholder="https://github.com/usuario/proyecto"
            style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
        </div>

        <div style="margin-bottom:18px;">
          <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
            Rama (opcional)
          </label>
          <input
            type="text"
            name="ramaGit"
            id="ramaGit"
            placeholder="main"
            style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
        </div>

      </div>

      <div id="bloqueExterno" style="display:none;">

        <div style="margin-bottom:18px;">
          <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
            URL o ruta de la demostración
          </label>
          <input
            type="text"
            name="urlDemo"
            id="urlDemo"
            placeholder="https://midemo.com"
            style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
          <small id="ayudaDemo" style="color:#6b7280;">
            Si es externa: <strong>https://midemo.com</strong>
          </small>
        </div>

      </div>

      <div id="bloqueRuntime" style="display:none;">

        <div style="margin-bottom:18px;">
          <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
            Comando de inicio (opcional)
          </label>
          <input
            type="text"
            name="comandoInicio"
            id="comandoInicio"
            placeholder="Ej: npm start o node app.js"
            style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
        </div>

        <div style="margin-bottom:18px;">
          <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
            Archivo de entrada (opcional)
          </label>
          <input
            type="text"
            name="archivoEntrada"
            id="archivoEntrada"
            placeholder="Ej: app.js"
            style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px;">
        </div>

      </div>

      <div style="margin-bottom:22px;">
        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#111827;">
          Descripción
        </label>
        <textarea
          name="descripcion"
          id="descripcion"
          rows="5"
          placeholder="Describe qué hace esta aplicación o demostración..."
          style="width:100%; padding:12px; border:1px solid #d1d5db; border-radius:10px; font-size:16px; resize:vertical;"></textarea>
      </div>

      <div id="cargaBox" style="display:none; margin-bottom:20px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
          <strong style="color:#111827;">Procesando proyecto...</strong>
          <span id="cargaTexto" style="color:#6b7280; font-size:14px;">Preparando...</span>
        </div>
        <div style="width:100%; height:14px; background:#e5e7eb; border-radius:999px; overflow:hidden;">
          <div id="barraCarga" style="width:0%; height:100%; background:#2563eb; transition:width .3s ease;"></div>
        </div>
      </div>

      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <button
          id="btnGuardarProyecto"
          type="submit"
          style="background:#2563eb; color:#fff; border:none; padding:12px 22px; border-radius:10px; font-size:16px; font-weight:bold; cursor:pointer;">
          Guardar proyecto
        </button>

        <a
          href="/dashboard"
          style="display:inline-block; background:#e5e7eb; color:#111827; padding:12px 22px; border-radius:10px; text-decoration:none; font-size:16px; font-weight:bold;">
          Volver
        </a>
      </div>

    </form>
  </div>
</div>

<script>
  function slugify(texto) {
    return (texto || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9\s-]/g, '')
      .trim()
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');
  }

  function cambiarMetodoEntrada() {
    const metodo = document.getElementById('metodoEntrada').value;
    const bloqueZip = document.getElementById('bloqueZip');
    const bloqueGit = document.getElementById('bloqueGit');
    const bloqueExterno = document.getElementById('bloqueExterno');
    const tipoSelect = document.getElementById('tipoProyecto');

    bloqueZip.style.display = 'none';
    bloqueGit.style.display = 'none';
    bloqueExterno.style.display = 'none';

    if (metodo === 'zip') {
      bloqueZip.style.display = 'block';
      tipoSelect.innerHTML = `
        <option value="html">Página HTML</option>
        <option value="node">Aplicación Node.js</option>
        <option value="sails">Aplicación Sails.js</option>
      `;
      tipoSelect.value = 'html';
    } else if (metodo === 'git') {
      bloqueGit.style.display = 'block';
      tipoSelect.innerHTML = `
        <option value="node">Aplicación Node.js</option>
        <option value="sails">Aplicación Sails.js</option>
        <option value="html">Página HTML</option>
      `;
      tipoSelect.value = 'node';
    } else {
      bloqueExterno.style.display = 'block';
      tipoSelect.innerHTML = `
        <option value="externo">Demostración externa</option>
      `;
      tipoSelect.value = 'externo';
    }

    cambiarTipoProyecto();
  }

  function cambiarTipoProyecto() {
    const tipo = document.getElementById('tipoProyecto').value;
    const metodo = document.getElementById('metodoEntrada').value;
    const bloqueRuntime = document.getElementById('bloqueRuntime');
    const bloqueCarpetaDemo = document.getElementById('bloqueCarpetaDemo');
    const ayudaArchivo = document.getElementById('ayudaArchivo');
    const tecnologia = document.getElementById('tecnologia');
    const urlDemo = document.getElementById('urlDemo');

    bloqueRuntime.style.display = 'none';

    if (bloqueCarpetaDemo) {
      bloqueCarpetaDemo.style.display = 'none';
    }

    if (tipo === 'html') {
      if (bloqueCarpetaDemo) bloqueCarpetaDemo.style.display = 'block';
      if (ayudaArchivo) {
        ayudaArchivo.innerHTML = 'Sube un archivo <strong>.html</strong> o un <strong>.zip</strong> con tu proyecto estático.';
      }
      if (!tecnologia.value) {
        tecnologia.value = 'HTML + CSS + JavaScript';
      }
    }

    if (tipo === 'node') {
      bloqueRuntime.style.display = 'block';
      if (!tecnologia.value) {
        tecnologia.value = 'Node.js';
      }
      if (ayudaArchivo && metodo === 'zip') {
        ayudaArchivo.innerHTML = 'Sube un archivo <strong>.zip</strong> del proyecto Node.js.';
      }
    }

    if (tipo === 'sails') {
      bloqueRuntime.style.display = 'block';
      if (!tecnologia.value) {
        tecnologia.value = 'Sails.js + Node.js';
      }
      if (ayudaArchivo && metodo === 'zip') {
        ayudaArchivo.innerHTML = 'Sube un archivo <strong>.zip</strong> del proyecto Sails.js.';
      }
    }

    if (tipo === 'externo') {
      if (!tecnologia.value) {
        tecnologia.value = 'Demo externa';
      }
      if (urlDemo) {
        urlDemo.placeholder = 'https://midemo.com';
      }
    }
  }

  function mostrarNombreArchivo() {
    const input = document.getElementById('archivoDemo');
    const box = document.getElementById('nombreArchivoSeleccionado');

    if (input.files && input.files[0]) {
      box.style.display = 'block';
      box.textContent = 'Archivo seleccionado: ' + input.files[0].name;

      const nombreBase = input.files[0].name.replace(/\.(zip|html|htm)$/i, '');
      const nombreInput = document.getElementById('nombre');
      const slugInput = document.getElementById('slug');
      const tipoSelect = document.getElementById('tipoProyecto');

      if (!nombreInput.value.trim()) {
        nombreInput.value = nombreBase;
      }

      if (!slugInput.value.trim()) {
        slugInput.value = slugify(nombreBase);
      }

      const lower = input.files[0].name.toLowerCase();

      if (lower.endsWith('.html') || lower.endsWith('.htm')) {
        tipoSelect.value = 'html';
      }

      cambiarTipoProyecto();
    }
  }

  function iniciarCargaVisual() {
    const cargaBox = document.getElementById('cargaBox');
    const barra = document.getElementById('barraCarga');
    const texto = document.getElementById('cargaTexto');
    const boton = document.getElementById('btnGuardarProyecto');

    cargaBox.style.display = 'block';
    boton.disabled = true;
    boton.textContent = 'Procesando...';
    boton.style.opacity = '0.7';
    boton.style.cursor = 'not-allowed';

    let progreso = 0;
    const pasos = [
      { hasta: 20, texto: 'Validando datos...' },
      { hasta: 45, texto: 'Subiendo contenido...' },
      { hasta: 70, texto: 'Procesando proyecto...' },
      { hasta: 90, texto: 'Finalizando...' }
    ];

    let indice = 0;

    const intervalo = setInterval(() => {
      if (indice < pasos.length) {
        const paso = pasos[indice];
        texto.textContent = paso.texto;

        if (progreso < paso.hasta) {
          progreso += 5;
          barra.style.width = progreso + '%';
        } else {
          indice++;
        }
      } else {
        clearInterval(intervalo);
      }
    }, 250);
  }

  document.getElementById('nombre').addEventListener('input', function () {
    const slugInput = document.getElementById('slug');
    if (!slugInput.dataset.editadoManualmente) {
      slugInput.value = slugify(this.value);
    }
  });

  document.getElementById('slug').addEventListener('input', function () {
    this.dataset.editadoManualmente = 'true';
  });

  document.getElementById('formProyecto').addEventListener('submit', function () {
    iniciarCargaVisual();
  });

  cambiarMetodoEntrada();
</script>