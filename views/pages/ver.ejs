<div style="font-family: Arial, sans-serif; background:#f5f7fb; min-height:100vh; padding:40px 20px;">
  <div style="max-width:1100px; margin:0 auto;">

    <div style="background:#fff; border-radius:18px; padding:30px; box-shadow:0 8px 24px rgba(0,0,0,0.08);">
      <h1 style="margin-top:0; color:#111827;"><%= proyecto.nombre %></h1>

      <p style="color:#374151;"><strong>Tipo:</strong> <%= proyecto.tipoProyecto || '-' %></p>
      <p style="color:#374151;"><strong>Tecnología:</strong> <%= proyecto.tecnologia || '-' %></p>
      <p style="color:#374151;"><strong>Estado:</strong> <%= proyecto.estado || 'borrador' %></p>
      <p style="color:#374151;">
        <strong>Precio propuesto:</strong>
        $<%= Number(proyecto.precioPropuesto || 0).toLocaleString('es-CO') %>
      </p>
      <p style="color:#6b7280; line-height:1.6;"><%= proyecto.descripcion || 'Sin descripción.' %></p>

      <div style="margin:20px 0;">
        <a href="<%= proyecto.urlDemo %>" target="_blank"
           style="display:inline-block; background:#2563eb; color:#fff; padding:12px 18px; border-radius:10px; text-decoration:none; font-weight:bold;">
          Ver demostración en vivo
        </a>

        <% if (proyecto.urlRepositorio) { %>
          <a href="<%= proyecto.urlRepositorio %>" target="_blank"
             style="display:inline-block; margin-left:10px; background:#111827; color:#fff; padding:12px 18px; border-radius:10px; text-decoration:none; font-weight:bold;">
            Ver repositorio
          </a>
        <% } %>

        <a href="/"
           style="display:inline-block; margin-left:10px; background:#e5e7eb; color:#111827; padding:12px 18px; border-radius:10px; text-decoration:none; font-weight:bold;">
          Volver
        </a>
      </div>

      <div style="margin-top:25px; border:1px solid #d1d5db; border-radius:14px; overflow:hidden;">
        <iframe
          src="<%= proyecto.urlDemo %>"
          style="width:100%; height:600px; border:none;">
        </iframe>
      </div>
    </div>

  </div>
</div>