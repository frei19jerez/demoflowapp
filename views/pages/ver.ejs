<%
  const esHtml = proyecto.tipoProyecto === 'html';

  const esDinamico =
    proyecto.tipoProyecto === 'node' ||
    proyecto.tipoProyecto === 'sails';

  const runtimeActivo =
    proyecto.estadoDeploy === 'activo';

  const demoUrl =
    proyecto.urlDemo &&
    proyecto.urlDemo.trim() !== ''
      ? proyecto.urlDemo.trim()
      : esDinamico
        ? `/runtime/${proyecto.slug}`
        : `/demo/${proyecto.slug}`;

  const estadoTexto =
    runtimeActivo
      ? '🟢 Runtime IA online'
      : '🔴 Runtime IA offline';
%>

<style>

  .ia-online{
    color:#4ade80;
  }

  .ia-offline{
    color:#f87171;
  }

  .btn-demo{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:13px 18px;
    border-radius:12px;
    text-decoration:none;
    font-weight:bold;
    transition:0.3s;
  }

  .btn-demo:hover{
    transform:translateY(-3px);
    opacity:0.95;
  }

  .ia-card{
    background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.08);
    border-radius:16px;
    padding:20px;
    transition:0.3s;
  }

  .ia-card:hover{
    transform:translateY(-4px);
    background:rgba(255,255,255,0.08);
  }

</style>

<div style="
  font-family:Arial,sans-serif;
  background:#f5f7fb;
  min-height:100vh;
  padding:40px 20px;
">

  <div style="
    max-width:1200px;
    margin:0 auto;
  ">

    <div style="
      background:#fff;
      border-radius:22px;
      padding:35px;
      box-shadow:0 10px 30px rgba(0,0,0,0.08);
    ">

      <!-- HEADER -->

      <div style="
        display:flex;
        justify-content:space-between;
        align-items:center;
        flex-wrap:wrap;
        gap:20px;
        margin-bottom:30px;
      ">

        <div>

          <h1 style="
            margin-top:0;
            margin-bottom:10px;
            color:#111827;
            font-size:40px;
          ">
            🚀 <%= proyecto.nombre %>
          </h1>

          <p style="
            color:#6b7280;
            font-size:17px;
            margin-bottom:0;
          ">
            Sistema administrado por DemoFlow IA
          </p>

        </div>

        <% if (usuario) { %>

          <div style="
            background:linear-gradient(135deg,#7c3aed,#2563eb);
            color:#fff;
            padding:15px 22px;
            border-radius:16px;
            font-weight:bold;
            box-shadow:0 8px 24px rgba(37,99,235,0.25);
          ">

            💎 Créditos IA:
            <%= usuario.creditos || 0 %>

          </div>

        <% } %>

      </div>

      <!-- GRID -->

      <div style="
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
        gap:18px;
        margin-bottom:30px;
      ">

        <div style="
          border:1px solid #e5e7eb;
          border-radius:16px;
          padding:22px;
        ">

          <h3 style="margin-top:0;">
            📦 Tipo
          </h3>

          <p style="
            margin-bottom:0;
            font-weight:bold;
          ">
            <%= proyecto.tipoProyecto || '-' %>
          </p>

        </div>

        <div style="
          border:1px solid #e5e7eb;
          border-radius:16px;
          padding:22px;
        ">

          <h3 style="margin-top:0;">
            🧠 Tecnología
          </h3>

          <p style="
            margin-bottom:0;
            font-weight:bold;
            color:#2563eb;
          ">
            <%= proyecto.tecnologia || '-' %>
          </p>

        </div>

        <div style="
          border:1px solid #e5e7eb;
          border-radius:16px;
          padding:22px;
        ">

          <h3 style="margin-top:0;">
            ⚡ Estado IA
          </h3>

          <p
            class="<%= runtimeActivo ? 'ia-online' : 'ia-offline' %>"
            style="
              margin-bottom:0;
              font-weight:bold;
            "
          >
            <%= estadoTexto %>
          </p>

        </div>

        <div style="
          border:1px solid #e5e7eb;
          border-radius:16px;
          padding:22px;
        ">

          <h3 style="margin-top:0;">
            🌐 Puerto
          </h3>

          <p style="
            margin-bottom:0;
            font-weight:bold;
          ">
            <%= proyecto.puerto || 'No asignado' %>
          </p>

        </div>

      </div>

      <!-- DESCRIPCIÓN -->

      <div style="
        background:#f9fafb;
        border:1px solid #e5e7eb;
        border-radius:18px;
        padding:25px;
        margin-bottom:35px;
      ">

        <h2 style="
          margin-top:0;
          color:#111827;
        ">
          📄 Descripción del proyecto
        </h2>

        <p style="
          color:#4b5563;
          line-height:1.9;
          font-size:16px;
          margin-bottom:0;
        ">
          <%= proyecto.descripcion || 'Sin descripción.' %>
        </p>

      </div>

      <!-- BOTONES -->

      <div style="
        display:flex;
        gap:14px;
        flex-wrap:wrap;
        margin-bottom:35px;
      ">

        <% if (esDinamico && !runtimeActivo) { %>

          <a
            href="/deploy/<%= proyecto.id %>/desplegar"
            class="btn-demo"
            style="
              background:#16a34a;
              color:#fff;
            "
          >
            🚀 Iniciar deploy IA
          </a>

        <% } %>

        <% if (demoUrl) { %>

          <a
            href="<%= demoUrl %>"
            target="_blank"
            class="btn-demo"
            style="
              background:#2563eb;
              color:#fff;
            "
          >
            🌐 Ver aplicación
          </a>

        <% } %>

        <% if (esDinamico) { %>

          <a
            href="/deploy/<%= proyecto.id %>/logs"
            class="btn-demo"
            style="
              background:#111827;
              color:#fff;
            "
          >
            📄 Logs IA
          </a>

          <a
            href="/deploy/<%= proyecto.id %>/reiniciar"
            class="btn-demo"
            style="
              background:#f59e0b;
              color:#111827;
            "
          >
            🔄 Reiniciar runtime
          </a>

          <a
            href="/deploy/<%= proyecto.id %>/detener"
            class="btn-demo"
            style="
              background:#dc2626;
              color:#fff;
            "
          >
            🛑 Detener runtime
          </a>

        <% } %>

        <% if (proyecto.urlRepositorio) { %>

          <a
            href="<%= proyecto.urlRepositorio %>"
            target="_blank"
            class="btn-demo"
            style="
              background:#0f172a;
              color:#fff;
            "
          >
            💻 Repositorio
          </a>

        <% } %>

      </div>

      <!-- IA ANALYZER -->

      <div style="
        background:linear-gradient(135deg,#0f172a,#1e293b);
        border-radius:24px;
        padding:30px;
        color:#fff;
        margin-bottom:35px;
      ">

        <h2 style="
          margin-top:0;
          font-size:34px;
        ">
          🤖 DemoFlow IA Analyzer
        </h2>

        <p style="
          color:#cbd5e1;
          line-height:1.9;
          font-size:16px;
        ">
          DemoFlow IA analiza automáticamente
          la estructura del proyecto,
          detecta tecnologías,
          verifica el runtime
          y evalúa el potencial SaaS.
        </p>

        <div style="
          display:grid;
          grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
          gap:18px;
          margin-top:25px;
        ">

          <div class="ia-card">

            <h3 style="margin-top:0;">
              🧠 IA Detectó
            </h3>

            <p style="
              color:#93c5fd;
              font-weight:bold;
              margin-bottom:0;
            ">
              <%= proyecto.tecnologia || 'Tecnología desconocida' %>
            </p>

          </div>

          <div class="ia-card">

            <h3 style="margin-top:0;">
              ⚡ Runtime IA
            </h3>

            <p
              class="<%= runtimeActivo ? 'ia-online' : 'ia-offline' %>"
              style="
                margin-bottom:0;
                font-weight:bold;
                font-size:17px;
              "
            >
              <%= estadoTexto %>
            </p>

          </div>

          <div class="ia-card">

            <h3 style="margin-top:0;">
              📈 Potencial SaaS
            </h3>

            <p style="
              color:#facc15;
              font-weight:bold;
              margin-bottom:0;
            ">
              Alto potencial comercial detectado por IA.
            </p>

          </div>

        </div>

        <% if (proyecto.analisisIa) { %>

          <div style="
            background:rgba(255,255,255,0.06);
            border-radius:18px;
            padding:24px;
            margin-top:28px;
            border:1px solid rgba(255,255,255,0.08);
          ">

            <h3 style="margin-top:0;">
              📄 Resultado del análisis IA
            </h3>

            <p style="
              color:#e2e8f0;
              line-height:1.9;
              margin-bottom:0;
            ">
              <%= proyecto.analisisIa %>
            </p>

          </div>

        <% } %>

        <!-- BOTÓN IA -->

        <% if (usuario) { %>

          <form
            action="/ia/analizar-proyecto"
            method="POST"
            style="
              margin-top:28px;
            "
          >

            <input
              type="hidden"
              name="nombre"
              value="<%= proyecto.nombre || '' %>"
            >

            <input
              type="hidden"
              name="tipoProyecto"
              value="<%= proyecto.tipoProyecto || '' %>"
            >

            <input
              type="hidden"
              name="tecnologia"
              value="<%= proyecto.tecnologia || '' %>"
            >

            <input
              type="hidden"
              name="urlRepositorio"
              value="<%= proyecto.urlRepositorio || '' %>"
            >

            <input
              type="hidden"
              name="urlDemo"
              value="<%= proyecto.urlDemo || '' %>"
            >

            <input
              type="hidden"
              name="archivoEntrada"
              value="<%= proyecto.archivoEntrada || '' %>"
            >

            <input
              type="hidden"
              name="comandoInicio"
              value="<%= proyecto.comandoInicio || '' %>"
            >

            <button
              type="submit"
              style="
                background:linear-gradient(135deg,#7c3aed,#2563eb);
                color:#fff;
                border:none;
                padding:15px 24px;
                border-radius:16px;
                font-weight:bold;
                font-size:16px;
                cursor:pointer;
              "
            >
              🤖 Analizar proyecto con IA
            </button>

          </form>

        <% } %>

      </div>

      <!-- DEMO -->

      <% if (esHtml && demoUrl) { %>

        <div style="
          margin-top:10px;
          border:1px solid #d1d5db;
          border-radius:18px;
          overflow:hidden;
          background:#fff;
          box-shadow:0 8px 24px rgba(0,0,0,0.06);
        ">

          <iframe
            src="<%= demoUrl %>"
            style="
              width:100%;
              height:720px;
              border:none;
            "
            loading="lazy">
          </iframe>

        </div>

      <% } else if (esDinamico && runtimeActivo) { %>

        <div style="
          margin-top:25px;
          border:1px solid #22c55e;
          background:#f0fdf4;
          border-radius:18px;
          padding:28px;
        ">

          <h3 style="
            margin-top:0;
            color:#166534;
          ">
            ✅ Runtime IA activo
          </h3>

          <p style="
            color:#14532d;
            line-height:1.9;
          ">
            DemoFlow IA detectó automáticamente
            el proyecto dinámico
            <strong><%= proyecto.tipoProyecto %></strong>
            y desplegó el runtime exitosamente.
          </p>

        </div>

      <% } else { %>

        <div style="
          margin-top:25px;
          border:1px solid #facc15;
          background:#fffbeb;
          border-radius:18px;
          padding:28px;
        ">

          <h3 style="
            margin-top:0;
            color:#92400e;
          ">
            ⚠ Runtime IA pendiente
          </h3>

          <p style="
            color:#78350f;
            line-height:1.9;
            margin-bottom:20px;
          ">
            DemoFlow IA detectó que el proyecto
            <strong><%= proyecto.tipoProyecto %></strong>
            todavía no ha sido desplegado.
          </p>

        </div>

      <% } %>

    </div>

  </div>

</div>