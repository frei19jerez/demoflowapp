<link rel="stylesheet" href="/styles/ver.css?v=3">

<%
  const esHtml = proyecto.tipoProyecto === 'html';

  const esDinamico =
    proyecto.tipoProyecto === 'node' ||
    proyecto.tipoProyecto === 'sails';

  const runtimeActivo =
    typeof runtimeOnline !== 'undefined'
      ? runtimeOnline
      : proyecto.estadoDeploy === 'activo';

  const demoUrl =
    proyecto.urlDemo &&
    proyecto.urlDemo.trim() !== ''
      ? proyecto.urlDemo.trim()
      : esDinamico
        ? `/runtime/${proyecto.slug}`
        : `/demo/${proyecto.slug}`;

  const estadoTexto =
    runtimeActivo
      ? 'Runtime online'
      : 'Runtime offline';
%>

<div class="proyecto-page">

  <div class="proyecto-container">

    <!-- HERO PROYECTO -->
    <section class="project-hero">

      <div class="project-hero-left">

        <span class="<%= runtimeActivo ? 'status-pill online' : 'status-pill offline' %>">
          <%= runtimeActivo ? '🟢' : '🔴' %> <%= estadoTexto %>
        </span>

        <h1>
          🚀 <%= proyecto.nombre %>
        </h1>

        <p>
          Aplicación administrada por DemoFlow IA, lista para publicar,
          compartir, presentar o vender.
        </p>

        <div class="project-url-box">
          <span>URL pública</span>
          <strong><%= demoUrl || 'Sin URL disponible' %></strong>
        </div>

      </div>

      <div class="project-hero-actions">

        <% if (usuario) { %>
          <div class="creditos-box">
            💎 Créditos IA: <%= usuario.creditos || 0 %>
          </div>
        <% } %>

        <% if (demoUrl) { %>
          <a href="<%= demoUrl %>" target="_blank" class="btn-demo btn-azul">
            🌐 Ver aplicación
          </a>
        <% } %>

        <% if (esDinamico && !runtimeActivo) { %>
          <a href="/deploy/<%= proyecto.id %>/desplegar" class="btn-demo btn-verde">
            🚀 Iniciar deploy IA
          </a>
        <% } %>

      </div>

    </section>

    <!-- MÉTRICAS -->
    <section class="info-grid">

      <div class="info-card">
        <span class="info-icon">📦</span>
        <h3>Tipo</h3>
        <p><%= proyecto.tipoProyecto || '-' %></p>
      </div>

      <div class="info-card">
        <span class="info-icon">🧠</span>
        <h3>Tecnología</h3>
        <p class="texto-azul"><%= proyecto.tecnologia || '-' %></p>
      </div>

      <div class="info-card">
        <span class="info-icon">⚡</span>
        <h3>Estado</h3>
        <p class="<%= runtimeActivo ? 'ia-online' : 'ia-offline' %>">
          <%= runtimeActivo ? 'Activo' : 'Inactivo' %>
        </p>
      </div>

      <div class="info-card">
        <span class="info-icon">🌐</span>
        <h3>Puerto</h3>
        <p><%= proyecto.puerto || 'No asignado' %></p>
      </div>

    </section>

    <!-- CENTRO DE CONTROL -->
<section class="control-center">

  <div class="section-top">
    <div>
      <h2>📊 Centro de control</h2>
      <p>
        Información rápida para administrar y presentar este proyecto.
      </p>
    </div>
  </div>

  <div class="control-grid">

    <div class="control-item">
      <span>🟢</span>
      <div>
        <h3>Runtime</h3>
        <p class="<%= runtimeActivo ? 'ia-online' : 'ia-offline' %>">
          <%= runtimeActivo ? 'Online' : 'Offline' %>
        </p>
      </div>
    </div>

    <div class="control-item">
      <span>🌐</span>
      <div>
        <h3>URL pública</h3>
        <p class="control-url"><%= demoUrl || 'Sin URL' %></p>
      </div>
    </div>

    <div class="control-item">
      <span>🧠</span>
      <div>
        <h3>Tecnología</h3>
        <p><%= proyecto.tecnologia || '-' %></p>
      </div>
    </div>

    <div class="control-item">
      <span>📦</span>
      <div>
        <h3>Tipo</h3>
        <p><%= proyecto.tipoProyecto || '-' %></p>
      </div>
    </div>

    <div class="control-item">
      <span>🚀</span>
      <div>
        <h3>Estado deploy</h3>
        <p><%= proyecto.estadoDeploy || proyecto.estado || 'borrador' %></p>
      </div>
    </div>

    <div class="control-item">
      <span>🔌</span>
      <div>
        <h3>Puerto</h3>
        <p><%= proyecto.puerto || 'No asignado' %></p>
      </div>
    </div>

  </div>

  <% if (demoUrl) { %>
    <div class="copy-box">
      <input
        id="demoUrlInput"
        type="text"
        value="<%= demoUrl %>"
        readonly>

      <button
        type="button"
        class="btn-demo btn-azul"
        onclick="navigator.clipboard.writeText(document.getElementById('demoUrlInput').value); this.innerText='✅ Copiado';">
        📋 Copiar URL
      </button>
    </div>
  <% } %>

</section>

    <!-- DESCRIPCIÓN Y ACCIONES -->
    <section class="project-main-grid">

      <div class="descripcion-box">

        <h2>📄 Descripción del proyecto</h2>

        <p>
          <%= proyecto.descripcion || 'Sin descripción.' %>
        </p>

      </div>

      <div class="actions-panel">

        <h2>⚙️ Acciones rápidas</h2>

        <p>
          Administra este proyecto sin salir de DemoFlow.
        </p>

        <div class="botones-box">

          <% if (demoUrl) { %>
            <a href="<%= demoUrl %>" target="_blank" class="btn-demo btn-azul">
              🌐 Ver aplicación
            </a>
          <% } %>

          <% if (proyecto.urlRepositorio) { %>

            <form
              action="/proyecto/<%= proyecto.id %>/actualizar-git"
              method="POST">

              <button
                type="submit"
                class="btn-demo btn-verde"
                onclick="return confirm('¿Actualizar este proyecto desde Git sin descontar créditos?')">
                🔄 Actualizar desde Git
              </button>

            </form>

          <% } else { %>

            <form
              action="/proyecto/<%= proyecto.id %>/reemplazar-archivos"
              method="POST"
              enctype="multipart/form-data">

              <label class="upload-label">
                ⬆️ Seleccionar archivo
                <input
                  type="file"
                  name="archivoDemo"
                  accept=".zip,.html,.htm"
                  required>
              </label>

              <button
                type="submit"
                class="btn-demo btn-verde"
                onclick="return confirm('¿Actualizar este proyecto desde tu PC sin descontar créditos?')">
                Actualizar desde mi PC
              </button>

            </form>

          <% } %>

        </div>

      </div>

    </section>

    <!-- VISTA PREVIA -->
    <% if (demoUrl) { %>

      <section class="preview-section">

        <div class="section-top">
          <div>
            <h2>🖥️ Vista previa en vivo</h2>
            <p>
              Esta es la aplicación publicada dentro de DemoFlow.
            </p>
          </div>

          <a href="<%= demoUrl %>" target="_blank" class="btn-demo btn-secondary">
            Abrir en nueva pestaña
          </a>
        </div>

        <div class="preview-frame-box">
          <iframe
            src="<%= demoUrl %>"
            loading="lazy">
          </iframe>
        </div>

      </section>

    <% } %>

    <!-- IA ANALYZER -->
    <section class="ia-analyzer">

      <div class="ia-analyzer-header">

        <div>
          <h2 class="ia-title">
            🤖 DemoFlow IA Analyzer
          </h2>

          <p class="ia-description">
            DemoFlow IA analiza automáticamente la estructura del proyecto,
            detecta tecnologías, verifica runtime y evalúa su potencial comercial.
          </p>
        </div>

        <% if (usuario) { %>

          <button
            id="btnAnalizarIA"
            type="button"
            class="btn-analizar-ia"
            data-id="<%= proyecto.id %>"
            data-nombre="<%= proyecto.nombre || '' %>"
            data-tipo="<%= proyecto.tipoProyecto || '' %>"
            data-tecnologia="<%= proyecto.tecnologia || '' %>"
            data-repo="<%= proyecto.urlRepositorio || '' %>"
            data-demo="<%= proyecto.urlDemo || '' %>"
            data-archivo="<%= proyecto.archivoEntrada || '' %>"
            data-comando="<%= proyecto.comandoInicio || '' %>">

            🤖 Analizar con IA

          </button>

        <% } %>

      </div>

      <div class="ia-grid">

        <div class="ia-card">
          <h3>🧠 IA detectó</h3>
          <p class="ia-detectado">
            <%= proyecto.tecnologia || 'Tecnología desconocida' %>
          </p>
        </div>

        <div class="ia-card">
          <h3>⚡ Runtime IA</h3>
          <p class="<%= runtimeActivo ? 'ia-online' : 'ia-offline' %>">
            <%= runtimeActivo ? 'Runtime online' : 'Runtime offline' %>
          </p>
        </div>

        <div class="ia-card">
          <h3>📈 Potencial SaaS</h3>
          <p class="ia-saas">
            Alto potencial comercial detectado por IA.
          </p>
        </div>

      </div>

      <!-- RESULTADO IA -->
      <div id="resultadoIA" class="resultado-ia" style="display:none;">

        <h3 class="resultado-title">
          🤖 Resultado IA
        </h3>

        <div class="ia-live-box">

          <div class="ia-live-top">

            <div class="ia-spinner"></div>

            <div>

              <div id="iaTextoEstado" class="ia-estado-texto">
                DemoFlow IA iniciando análisis...
              </div>

              <div class="ia-subestado">
                Runtime inteligente procesando proyecto.
              </div>

            </div>

          </div>

          <div class="ia-progress">
            <div id="iaBarra" class="ia-progress-bar"></div>
          </div>

          <div id="iaLogs" class="ia-logs">
            🤖 DemoFlow IA esperando instrucciones...
          </div>

          <div id="contenidoResultadoIA" class="contenido-resultado-ia">
            ⏳ Preparando análisis...
          </div>

        </div>

      </div>

    </section>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script src="/js/ver.js?v=2026052604"></script>

<script src="/js/proyecto-ia.js?v=2026072301"></script>