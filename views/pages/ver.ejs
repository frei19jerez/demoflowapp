<%
  const esHtml = proyecto.tipoProyecto === 'html';

  const esDinamico =
    proyecto.tipoProyecto === 'node' ||
    proyecto.tipoProyecto === 'sails';

  const runtimeActivo =
    proyecto.estadoDeploy === 'activo';

  const demoUrl =
    proyecto.urlDemo &&
    proyecto.urlDemo.trim() !== ''
      ? proyecto.urlDemo.trim()
      : esDinamico
        ? `/runtime/${proyecto.slug}`
        : `/demo/${proyecto.slug}`;

  const estadoTexto =
    runtimeActivo
      ? '🟢 Runtime IA online'
      : '🔴 Runtime IA offline';
%>

<style>

  .ia-online{
    color:#4ade80;
  }

  .ia-offline{
    color:#f87171;
  }

  .btn-demo{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:13px 18px;
    border-radius:12px;
    text-decoration:none;
    font-weight:bold;
    transition:0.3s;
  }

  .btn-demo:hover{
    transform:translateY(-3px);
    opacity:0.95;
  }

  .ia-card{
    background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.08);
    border-radius:16px;
    padding:20px;
    transition:0.3s;
  }

  .ia-card:hover{
    transform:translateY(-4px);
    background:rgba(255,255,255,0.08);
  }

</style>

<div style="
  font-family:Arial,sans-serif;
  background:#f5f7fb;
  min-height:100vh;
  padding:40px 20px;
">

  <div style="
    max-width:1200px;
    margin:0 auto;
  ">

    <div style="
      background:#fff;
      border-radius:22px;
      padding:35px;
      box-shadow:0 10px 30px rgba(0,0,0,0.08);
    ">

      <!-- HEADER -->

      <div style="
        display:flex;
        justify-content:space-between;
        align-items:center;
        flex-wrap:wrap;
        gap:20px;
        margin-bottom:30px;
      ">

        <div>

          <h1 style="
            margin-top:0;
            margin-bottom:10px;
            color:#111827;
            font-size:40px;
          ">
            🚀 <%= proyecto.nombre %>
          </h1>

          <p style="
            color:#6b7280;
            font-size:17px;
            margin-bottom:0;
          ">
            Sistema administrado por DemoFlow IA
          </p>

        </div>

        <% if (usuario) { %>

          <div style="
            background:linear-gradient(135deg,#7c3aed,#2563eb);
            color:#fff;
            padding:15px 22px;
            border-radius:16px;
            font-weight:bold;
            box-shadow:0 8px 24px rgba(37,99,235,0.25);
          ">

            💎 Créditos IA:
            <%= usuario.creditos || 0 %>

          </div>

        <% } %>

      </div>

      <!-- GRID -->

      <div style="
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
        gap:18px;
        margin-bottom:30px;
      ">

        <div style="
          border:1px solid #e5e7eb;
          border-radius:16px;
          padding:22px;
        ">

          <h3 style="margin-top:0;">
            📦 Tipo
          </h3>

          <p style="
            margin-bottom:0;
            font-weight:bold;
          ">
            <%= proyecto.tipoProyecto || '-' %>
          </p>

        </div>

        <div style="
          border:1px solid #e5e7eb;
          border-radius:16px;
          padding:22px;
        ">

          <h3 style="margin-top:0;">
            🧠 Tecnología
          </h3>

          <p style="
            margin-bottom:0;
            font-weight:bold;
            color:#2563eb;
          ">
            <%= proyecto.tecnologia || '-' %>
          </p>

        </div>

        <div style="
          border:1px solid #e5e7eb;
          border-radius:16px;
          padding:22px;
        ">

          <h3 style="margin-top:0;">
            ⚡ Estado IA
          </h3>

          <p
            class="<%= runtimeActivo ? 'ia-online' : 'ia-offline' %>"
            style="
              margin-bottom:0;
              font-weight:bold;
            "
          >
            <%= estadoTexto %>
          </p>

        </div>

        <div style="
          border:1px solid #e5e7eb;
          border-radius:16px;
          padding:22px;
        ">

          <h3 style="margin-top:0;">
            🌐 Puerto
          </h3>

          <p style="
            margin-bottom:0;
            font-weight:bold;
          ">
            <%= proyecto.puerto || 'No asignado' %>
          </p>

        </div>

      </div>

      <!-- DESCRIPCIÓN -->

      <div style="
        background:#f9fafb;
        border:1px solid #e5e7eb;
        border-radius:18px;
        padding:25px;
        margin-bottom:35px;
      ">

        <h2 style="
          margin-top:0;
          color:#111827;
        ">
          📄 Descripción del proyecto
        </h2>

        <p style="
          color:#4b5563;
          line-height:1.9;
          font-size:16px;
          margin-bottom:0;
        ">
          <%= proyecto.descripcion || 'Sin descripción.' %>
        </p>

      </div>

      <!-- BOTONES -->

      <div style="
        display:flex;
        gap:14px;
        flex-wrap:wrap;
        margin-bottom:35px;
      ">

        <% if (esDinamico && !runtimeActivo) { %>

          <a
            href="/deploy/<%= proyecto.id %>/desplegar"
            class="btn-demo"
            style="
              background:#16a34a;
              color:#fff;
            "
          >
            🚀 Iniciar deploy IA
          </a>

        <% } %>

        <% if (demoUrl) { %>

          <a
            href="<%= demoUrl %>"
            target="_blank"
            class="btn-demo"
            style="
              background:#2563eb;
              color:#fff;
            "
          >
            🌐 Ver aplicación
          </a>

        <% } %>

      </div>

      <!-- IA ANALYZER -->

      <div style="
        background:linear-gradient(135deg,#0f172a,#1e293b);
        border-radius:24px;
        padding:30px;
        color:#fff;
        margin-bottom:35px;
      ">

        <h2 style="
          margin-top:0;
          font-size:34px;
        ">
          🤖 DemoFlow IA Analyzer
        </h2>

        <p style="
          color:#cbd5e1;
          line-height:1.9;
          font-size:16px;
        ">
          DemoFlow IA analiza automáticamente
          la estructura del proyecto,
          detecta tecnologías,
          verifica el runtime
          y evalúa el potencial SaaS.
        </p>

        <div style="
          display:grid;
          grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
          gap:18px;
          margin-top:25px;
        ">

          <div class="ia-card">

            <h3 style="margin-top:0;">
              🧠 IA Detectó
            </h3>

            <p style="
              color:#93c5fd;
              font-weight:bold;
              margin-bottom:0;
            ">
              <%= proyecto.tecnologia || 'Tecnología desconocida' %>
            </p>

          </div>

          <div class="ia-card">

            <h3 style="margin-top:0;">
              ⚡ Runtime IA
            </h3>

            <p
              class="<%= runtimeActivo ? 'ia-online' : 'ia-offline' %>"
              style="
                margin-bottom:0;
                font-weight:bold;
                font-size:17px;
              "
            >
              <%= estadoTexto %>
            </p>

          </div>

          <div class="ia-card">

            <h3 style="margin-top:0;">
              📈 Potencial SaaS
            </h3>

            <p style="
              color:#facc15;
              font-weight:bold;
              margin-bottom:0;
            ">
              Alto potencial comercial detectado por IA.
            </p>

          </div>

        </div>

        <!-- RESULTADO IA -->

        <div
          id="resultadoIA"
          style="
            display:none;
            margin-top:24px;
            background:rgba(255,255,255,0.06);
            border-radius:18px;
            padding:24px;
            border:1px solid rgba(255,255,255,0.08);
          "
        >

          <h3 style="margin-top:0;">
            🤖 Resultado IA
          </h3>

          <div
            id="contenidoResultadoIA"
            style="
              color:#e2e8f0;
              line-height:1.9;
            "
          >
            Analizando proyecto...
          </div>

        </div>

        <!-- BOTÓN IA -->

        <% if (usuario) { %>

          <div style="margin-top:28px;">

            <button
              id="btnAnalizarIA"
              type="button"
              style="
                background:linear-gradient(135deg,#7c3aed,#2563eb);
                color:#fff;
                border:none;
                padding:15px 24px;
                border-radius:16px;
                font-weight:bold;
                font-size:16px;
                cursor:pointer;
              "
            >
              🤖 Analizar proyecto con IA
            </button>

          </div>

        <% } %>

      </div>

    </div>

  </div>

</div>

<script>

  const btnIA = document.getElementById('btnAnalizarIA');
  const resultadoIA = document.getElementById('resultadoIA');
  const contenidoIA = document.getElementById('contenidoResultadoIA');

  if (btnIA) {

    btnIA.addEventListener('click', async function() {

      btnIA.disabled = true;
      btnIA.innerText = '🤖 Analizando proyecto...';

      resultadoIA.style.display = 'block';

      contenidoIA.innerHTML =
        '⏳ DemoFlow IA está analizando el proyecto...';

      try {

        const respuesta = await fetch('/ia/analizar-proyecto', {
          method: 'POST',

          headers: {
            'Content-Type': 'application/json'
          },

          body: JSON.stringify({

            nombre: '<%= proyecto.nombre || "" %>',
            tipoProyecto: '<%= proyecto.tipoProyecto || "" %>',
            tecnologia: '<%= proyecto.tecnologia || "" %>',
            urlRepositorio: '<%= proyecto.urlRepositorio || "" %>',
            urlDemo: '<%= proyecto.urlDemo || "" %>',
            archivoEntrada: '<%= proyecto.archivoEntrada || "" %>',
            comandoInicio: '<%= proyecto.comandoInicio || "" %>'

          })
        });

        const data = await respuesta.json();

        contenidoIA.innerHTML = `
          <p><strong>🧠 Tipo detectado:</strong> ${data.tipoDetectado || '-'}</p>
          <p><strong>📄 Archivo recomendado:</strong> ${data.archivoRecomendado || '-'}</p>
          <p><strong>⚙️ Comando recomendado:</strong> ${data.comandoRecomendado || '-'}</p>
          <p><strong>🤖 Resultado IA:</strong> ${data.mensaje || 'Análisis completado.'}</p>
        `;

      } catch (error) {

        contenidoIA.innerHTML =
          '❌ DemoFlow IA no pudo analizar el proyecto.';

        console.error(error);
      }

      btnIA.disabled = false;

      btnIA.innerText =
        '🤖 Analizar proyecto con IA';

    });

  }

</script>