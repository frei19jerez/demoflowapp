<link rel="stylesheet" href="/styles/homepage.css?v=7">

<div class="home-page">

  <div class="home-container">

    <!-- ENCABEZADO -->
    <div class="home-header">
      <div>
        <h1>🚀 DemoFlow</h1>
        <p>Publica, comparte y presenta tus aplicaciones al mundo.</p>
      </div>

      <a href="/proyecto/nuevo" class="btn-primary">
        + Nuevo proyecto
      </a>
    </div>

    <!-- HERO -->
    <section class="hero-card">
      <h2>Crea. Publica. Comparte. Impresiona.</h2>

      <p>
        DemoFlow es una plataforma para programadores, freelancers, estudiantes,
        startups y empresas que necesitan mostrar sus aplicaciones en vivo.
        Sube tu proyecto desde Git o desde tu computador, obtén un enlace público
        y compártelo con clientes, amigos, profesores, empresas o inversionistas.
      </p>

      <div class="hero-actions">
        <a href="/proyecto/nuevo" class="btn-white">
          Crear mi primer demo
        </a>

        <a href="#video-demo" class="btn-outline-white">
          Ver cómo funciona
        </a>
      </div>
    </section>

    <!-- VIDEO YOUTUBE -->
    <section class="video-card" id="video-demo">

      <div class="video-info">

        <span class="mini-label">🎥 Video explicativo</span>

        <h2>Aprende DemoFlow en pocos minutos</h2>

        <p>
          Mira este video donde explico cómo publicar una aplicación,
          compartirla con clientes, empresas, profesores, amigos o inversionistas
          y administrar todos tus proyectos desde DemoFlow.
        </p>

        <a href="/proyecto/nuevo" class="btn-primary">
          Crear mi proyecto
        </a>

      </div>

      <div class="video-player">
        <iframe
          src="https://www.youtube.com/embed/TU_VIDEO"
          title="Video explicativo de DemoFlow"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen>
        </iframe>
      </div>

    </section>

    <!-- COMO FUNCIONA -->
    <section class="steps-card">

      <div class="section-head">
        <span class="mini-label">⚙️ Proceso simple</span>
        <h2>¿Cómo funciona DemoFlow?</h2>
        <p>
          Publica una aplicación en pocos pasos y compártela con cualquier persona desde un enlace.
        </p>
      </div>

      <div class="steps-grid">

        <div class="step-card">
          <span>1</span>
          <h3>Sube tu proyecto</h3>
          <p>Importa desde Git o sube tus archivos desde el computador.</p>
        </div>

        <div class="step-card">
          <span>2</span>
          <h3>DemoFlow IA analiza</h3>
          <p>La plataforma detecta la tecnología y prepara el proyecto.</p>
        </div>

        <div class="step-card">
          <span>3</span>
          <h3>Se crea el runtime</h3>
          <p>DemoFlow inicia tu aplicación con PM2 y genera una URL pública.</p>
        </div>

        <div class="step-card">
          <span>4</span>
          <h3>Comparte y vende</h3>
          <p>Presenta tu app a clientes, empresas, profesores o inversionistas.</p>
        </div>

      </div>

    </section>

    <!-- IA DEMOFLOW -->
    <section class="ia-card">

      <div class="ia-header">
        <div>
          <h2>🤖 DemoFlow IA</h2>
          <p>Inteligencia artificial para analizar, optimizar y presentar proyectos.</p>
        </div>

        <div class="ia-creditos">
          💎 Créditos IA:
          <%= usuario && usuario.creditos ? usuario.creditos : 0 %>
        </div>
      </div>

      <div class="ia-grid">

        <div class="info-card">
          <h3>🚀 Estado IA</h3>

          <% if (usuario && usuario.acceso_ia) { %>
            <p class="estado-ok">IA activada correctamente</p>
          <% } else { %>
            <p class="estado-error">Sin acceso IA</p>
          <% } %>
        </div>

        <div class="info-card">
          <h3>📈 Recomendación IA</h3>
          <p>
            Agrega capturas, demos en vivo y enlaces GitHub para aumentar la confianza del cliente.
          </p>
        </div>

        <div class="info-card">
          <h3>🔥 Potencial comercial</h3>
          <p class="texto-azul">
            Tus aplicaciones pueden convertirse en productos, demos, portafolios o propuestas de venta.
          </p>
        </div>

        <div class="info-card">
          <h3>🌐 Deploy inteligente</h3>
          <p>
            DemoFlow IA detecta HTML, Node.js, Sails, React y otras tecnologías en crecimiento.
          </p>
        </div>

      </div>

    </section>

    <!-- TECNOLOGÍAS -->
    <section class="tech-card">

      <div class="section-head">
        <span class="mini-label">🧩 Tecnologías</span>
        <h2>Una plataforma para diferentes tipos de proyectos</h2>
        <p>
          DemoFlow está pensado para crecer y soportar cada vez más tecnologías usadas por desarrolladores.
        </p>
      </div>

      <div class="tech-grid">
        <span>HTML</span>
        <span>CSS</span>
        <span>JavaScript</span>
        <span>Node.js</span>
        <span>Sails.js</span>
        <span>Express</span>
        <span>React</span>
        <span>GitHub</span>
        <span>PostgreSQL</span>
        <span>PM2</span>
      </div>

    </section>

    <!-- LISTADO -->
    <h2 class="section-title">Proyectos en demo</h2>

    <% if (proyectos && proyectos.length > 0) { %>

      <div class="proyectos-grid">

        <% proyectos.forEach(function(p) { %>

          <article class="proyecto-card">

            <div class="preview-box">
              <% if (p.urlDemo) { %>

                <iframe
                  src="<%= p.urlDemo %>"
                  class="preview-frame"
                  loading="lazy">
                </iframe>

              <% } else { %>

                <div class="preview-empty">
                  Sin vista previa disponible
                </div>

              <% } %>
            </div>

            <div class="proyecto-body">

              <h3><%= p.nombre %></h3>

              <p>
                <strong>Cliente:</strong>
                <%= p.clienteId || '-' %>
              </p>

              <p>
                <strong>Tecnología:</strong>
                <%= p.tecnologia || '-' %>
              </p>

              <p class="descripcion">
                <%= p.descripcion || 'Sin descripción.' %>
              </p>

              <p>
                <span class="badge">
                  <%= p.estado || 'borrador' %>
                </span>
              </p>

              <div class="acciones-card">

                <% if (p.urlDemo) { %>
                  <a href="<%= p.urlDemo %>" target="_blank" class="btn-primary">
                    Ver en vivo
                  </a>
                <% } %>

                <a href="/proyecto/<%= p.id %>" class="btn-secondary">
                  Ver detalle
                </a>

                <form
                  action="/proyecto/<%= p.id %>/eliminar"
                  method="POST"
                  onsubmit="return confirm('¿Seguro que deseas eliminar este proyecto? Esta acción no se puede deshacer.');">

                  <input type="hidden" name="_csrf" value="<%= _csrf %>">

                  <button type="submit" class="btn-danger">
                    🗑️ Eliminar
                  </button>

                </form>

              </div>

            </div>

          </article>

        <% }) %>

      </div>

    <% } else { %>

      <div class="empty-card">
        <h3>Todavía no hay proyectos</h3>
        <p>
          Empieza creando tu primer demo para compartirlo con el mundo.
        </p>

        <a href="/proyecto/nuevo" class="btn-primary">
          Crear proyecto
        </a>
      </div>

    <% } %>

  </div>

</div>