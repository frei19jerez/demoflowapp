<link rel="stylesheet" href="/styles/homepage.css?v=1">

<div class="home-page">

  <div class="home-container">

    <!-- ENCABEZADO -->
    <div class="home-header">
      <div>
        <h1>🚀 DemoFlow</h1>
        <p>Muestra tus apps en vivo a tus clientes antes de venderlas.</p>
      </div>

      <a href="/proyecto/nuevo" class="btn-primary">
        + Nuevo proyecto
      </a>
    </div>

    <!-- HERO -->
    <section class="hero-card">
      <h2>Comparte demos en vivo con tus clientes</h2>
      <p>
        DemoFlow te permite guardar proyectos, mostrar enlaces en vivo, presentar páginas HTML,
        apps en Sails, Node o cualquier tecnología, y dejar que el cliente vea el borrador antes de comprar.
      </p>

      <a href="/proyecto/nuevo" class="btn-white">
        Crear mi primer demo
      </a>
    </section>

    <!-- IA DEMOFLOW -->
    <section class="ia-card">

      <div class="ia-header">
        <div>
          <h2>🤖 DemoFlow IA</h2>
          <p>Inteligencia artificial para analizar, optimizar y vender proyectos.</p>
        </div>

        <div class="ia-creditos">
          💎 Créditos IA:
          <%= usuario && usuario.creditos ? usuario.creditos : 0 %>
        </div>
      </div>

      <div class="ia-grid">

        <div class="info-card">
          <h3>🚀 Estado IA</h3>

          <% if (usuario && usuario.acceso_ia) { %>
            <p class="estado-ok">IA activada correctamente</p>
          <% } else { %>
            <p class="estado-error">Sin acceso IA</p>
          <% } %>
        </div>

        <div class="info-card">
          <h3>📈 Recomendación IA</h3>
          <p>
            Agrega capturas, demos en vivo y enlaces GitHub para aumentar conversiones.
          </p>
        </div>

        <div class="info-card">
          <h3>🔥 Potencial SaaS</h3>
          <p class="texto-azul">
            Tu perfil tiene potencial comercial para vender software.
          </p>
        </div>

        <div class="info-card">
          <h3>🌐 Deploy Inteligente</h3>
          <p>
            DemoFlow IA detecta HTML, Node.js, Sails y React automáticamente.
          </p>
        </div>

      </div>

    </section>

    <!-- LISTADO -->
    <h2 class="section-title">Proyectos en demo</h2>

    <% if (proyectos && proyectos.length > 0) { %>

      <div class="proyectos-grid">

        <% proyectos.forEach(function(p) { %>

          <article class="proyecto-card">

            <div class="preview-box">
              <% if (p.urlDemo) { %>

                <iframe
                  src="<%= p.urlDemo %>"
                  class="preview-frame"
                  loading="lazy">
                </iframe>

              <% } else { %>

                <div class="preview-empty">
                  Sin vista previa disponible
                </div>

              <% } %>
            </div>

            <div class="proyecto-body">

              <h3><%= p.nombre %></h3>

              <p>
                <strong>Cliente:</strong>
                <%= p.clienteId || '-' %>
              </p>

              <p>
                <strong>Tecnología:</strong>
                <%= p.tecnologia || '-' %>
              </p>

              <p class="descripcion">
                <%= p.descripcion || 'Sin descripción.' %>
              </p>

              <p>
                <span class="badge">
                  <%= p.estado || 'borrador' %>
                </span>
              </p>

              <div class="acciones-card">

                <% if (p.urlDemo) { %>
                  <a href="<%= p.urlDemo %>" target="_blank" class="btn-primary">
                    Ver en vivo
                  </a>
                <% } %>

                <a href="/proyecto/<%= p.id %>" class="btn-secondary">
                  Ver detalle
                </a>

                <form
                  action="/proyecto/<%= p.id %>/eliminar"
                  method="POST"
                  onsubmit="return confirm('¿Seguro que deseas eliminar este proyecto? Esta acción no se puede deshacer.');"
                  >
                 <input type="hidden" name="_csrf" value="<%= _csrf %>">

                 <button type="submit" class="btn-danger">
                    🗑️ Eliminar
                 </button>
             </form>

              </div>

            </div>

          </article>

        <% }) %>

      </div>

    <% } else { %>

      <div class="empty-card">
        <h3>Todavía no hay proyectos</h3>
        <p>
          Empieza creando tu primer demo para mostrárselo a un cliente.
        </p>

        <a href="/proyecto/nuevo" class="btn-primary">
          Crear proyecto
        </a>
      </div>

    <% } %>

  </div>

</div>