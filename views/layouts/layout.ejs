<!DOCTYPE html>
<html lang="es">
<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>DemoFlow IA | Freimel Jerez</title>

  <meta
    name="description"
    content="DemoFlow IA plataforma desarrollada por Freimel Jerez para publicar demos, proyectos Node.js, Sails.js, HTML, CSS, JavaScript y aplicaciones web modernas."
  >

  <meta
    name="keywords"
    content="DemoFlow, Freimel Jerez, IA, Sails.js, Node.js, PostgreSQL, Deploy, HTML, CSS, JavaScript"
  >

  <meta name="author" content="Freimel Jerez">
  <meta name="robots" content="index, follow">

  <meta property="og:title" content="DemoFlow IA">
  <meta property="og:description" content="Plataforma IA para demos y despliegues web.">
  <meta property="og:type" content="website">

  <!-- Bootstrap disponible, pero sin envolver las páginas -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  >

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  >

  <style>
    html{
      scroll-behavior:smooth;
    }

    body{
      margin:0;
      min-height:100vh;
      font-family:'Inter', Segoe UI, Roboto, Arial, sans-serif;
      background:#f5f7fb;
      color:#111827;
    }

    .ia-badge{
      display:inline-flex;
      align-items:center;
      gap:6px;
      background:linear-gradient(90deg,#2563eb,#7c3aed);
      color:white;
      padding:6px 14px;
      border-radius:999px;
      font-size:13px;
      font-weight:700;
    }

    .footer-demo{
      background:#111827;
      color:white;
      padding:18px;
      text-align:center;
      font-size:14px;
    }

    .footer-demo strong{
      color:#93c5fd;
    }
  </style>

</head>

<body>

  <%- include('../partials/header') %>

  <%- body %>

  <footer class="footer-demo">
    🚀 DemoFlow IA | Desarrollado por
    <strong>Freimel Jerez</strong>
    con Node.js, Sails.js, PostgreSQL e IA.
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>s