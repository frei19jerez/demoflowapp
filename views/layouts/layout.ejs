<!DOCTYPE html>
<html lang="es">

<head>

  <!-- ========================= -->
  <!-- META -->
  <!-- ========================= -->

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>
    DemoFlow IA | Freimel Jerez
  </title>

  <!-- ========================= -->
  <!-- SEO -->
  <!-- ========================= -->

  <meta
    name="description"
    content="DemoFlow IA plataforma desarrollada por Freimel Jerez para publicar demos, proyectos Node.js, Sails.js, HTML, CSS, JavaScript y aplicaciones web modernas."
  >

  <meta
    name="keywords"
    content="DemoFlow, Freimel Jerez, IA, Sails.js, Node.js, PostgreSQL, Deploy, HTML, CSS, JavaScript"
  >

  <meta
    name="author"
    content="Freimel Jerez"
  >

  <meta
    name="robots"
    content="index, follow"
  >

  <!-- ========================= -->
  <!-- OPEN GRAPH -->
  <!-- ========================= -->

  <meta property="og:title" content="DemoFlow IA">
  <meta property="og:description" content="Plataforma IA para demos y despliegues web.">
  <meta property="og:type" content="website">

  <!-- ========================= -->
  <!-- BOOTSTRAP -->
  <!-- ========================= -->

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <!-- ========================= -->
  <!-- ICONOS -->
  <!-- ========================= -->

  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  >

  <!-- ========================= -->
  <!-- GOOGLE FONTS -->
  <!-- ========================= -->

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  >

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  >

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  >

  <!-- ========================= -->
  <!-- ESTILOS -->
  <!-- ========================= -->

  <style>

    body{
      margin:0;
      font-family:'Inter',sans-serif;
      background:#f5f7fb;
      color:#111827;
      display:flex;
      flex-direction:column;
      min-height:100vh;
    }

    .main-container{
      flex:1;
      padding:20px;
    }

    .df-card{
      background:white;
      border-radius:18px;
      padding:20px;
      box-shadow:0 10px 25px rgba(0,0,0,0.06);
      border:1px solid #e5e7eb;
    }

    .ia-badge{
      background:linear-gradient(
        90deg,
        #2563eb,
        #7c3aed
      );

      color:white;

      padding:6px 14px;

      border-radius:999px;

      font-size:13px;

      font-weight:600;
    }

    .footer-demo{
      background:#111827;
      color:white;
      padding:18px;
      text-align:center;
      font-size:14px;
    }

  </style>

</head>

<body>

  <!-- ========================= -->
  <!-- HEADER -->
  <!-- ========================= -->

  <%- include('../partials/header') %>

  <!-- ========================= -->
  <!-- CONTENIDO -->
  <!-- ========================= -->

  <main class="main-container">

    <div class="container-fluid">

      <!-- IA -->
      <div class="mb-3">

        <span class="ia-badge">
          🤖 DemoFlow IA
        </span>

      </div>

      <!-- BODY -->
      <div class="df-card">

        <%- body %>

      </div>

    </div>

  </main>

  <!-- ========================= -->
  <!-- FOOTER -->
  <!-- ========================= -->

  <footer class="footer-demo">

    🚀 DemoFlow IA |
    Desarrollado por
    <strong>Freimel Jerez</strong>
    con Node.js, Sails.js, PostgreSQL e IA.

  </footer>

  <!-- ========================= -->
  <!-- BOOTSTRAP JS -->
  <!-- ========================= -->

  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
  </script>

</body>
</html>