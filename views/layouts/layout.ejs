<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof titulo !== 'undefined' ? titulo + ' | DemoFlow' : 'DemoFlow' %></title>
</head>

<body style="margin:0; font-family:Arial, sans-serif; background:#f5f7fb; display:flex; flex-direction:column; min-height:100vh;">

  <!-- HEADER -->
  <header style="background:#ffffff; border-bottom:1px solid #e5e7eb; padding:16px 20px;">
    <div style="max-width:1100px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; gap:15px; flex-wrap:wrap;">
      <a href="/" style="text-decoration:none; color:#111827; font-size:28px; font-weight:bold;">
        🚀 DemoFlow
      </a>

      <nav style="display:flex; gap:10px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#374151; padding:10px 14px; border-radius:8px; background:#f3f4f6;">Inicio</a>
        <a href="/login" style="text-decoration:none; color:#2563eb; padding:10px 14px; border-radius:8px; border:1px solid #2563eb;">Login</a>
        <a href="/register" style="text-decoration:none; color:#ffffff; padding:10px 14px; border-radius:8px; background:#2563eb;">Registro</a>
      </nav>
    </div>
  </header>

  <!-- CONTENIDO -->
  <main style="flex:1; width:100%; max-width:1100px; margin:0 auto; padding:30px 20px;">
    <%- body %>
  </main>

  <!-- FOOTER -->
  <footer style="background:#ffffff; border-top:1px solid #e5e7eb; padding:18px 20px; margin-top:auto;">
    <div style="max-width:1100px; margin:0 auto; text-align:center; color:#6b7280; font-size:14px;">
      © <%= new Date().getFullYear() %> DemoFlow - Plataforma para mostrar demos a clientes.
    </div>
  </footer>

</body>
</html>